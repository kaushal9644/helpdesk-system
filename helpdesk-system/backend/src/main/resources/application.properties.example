# Copy to application-local.properties or set as environment variables.
# Never commit real secrets to version control.

spring.datasource.url=jdbc:mysql://localhost:3306/helpdesk_db?useSSL=true&serverTimezone=UTC
spring.datasource.username=helpdesk_user
spring.datasource.password=CHANGE_ME

app.jwt.secret=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARACTERS
app.jwt.expiration-ms=86400000

app.cors.allowed-origins=https://your-frontend-domain.com
app.dev.seed-enabled=false
